#!/usr/bin/env bash
# Helper: sources AWS credentials from secrets.yaml into the environment.
# Usage: eval "$(.mise/lib/load-secrets)"
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
SECRETS_FILE="$PROJECT_DIR/secrets.yaml"

if [[ ! -f "$SECRETS_FILE" ]]; then
    echo "Error: $SECRETS_FILE not found" >&2
    exit 1
fi

# Parse YAML with simple grep/sed — no yq dependency needed for flat keys
AWS_ACCESS_KEY_ID=$(grep 'access_key_id:' "$SECRETS_FILE" | sed 's/.*: *//')
AWS_SECRET_ACCESS_KEY=$(grep 'secret_access_key:' "$SECRETS_FILE" | sed 's/.*: *//')
GITHUB_PAT_MGMT=$(grep 'github_pat_mgmt:' "$SECRETS_FILE" | sed 's/.*: *//')

echo "export AWS_ACCESS_KEY_ID='$AWS_ACCESS_KEY_ID'"
echo "export AWS_SECRET_ACCESS_KEY='$AWS_SECRET_ACCESS_KEY'"
echo "export AWS_DEFAULT_REGION='eu-central-1'"
echo "export GITHUB_PAT_MGMT='$GITHUB_PAT_MGMT'"
