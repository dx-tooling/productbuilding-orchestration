#!/usr/bin/env bash
#MISE description="Onboard a new target repo (interactive)"
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
TFVARS_FILE="$PROJECT_DIR/infrastructure-mgmt/main/targets.auto.tfvars"

echo "Target repo onboarding"
echo "======================"
echo ""

# --- Repo identity ---

read -rp "Repo owner [luminor-project]: " REPO_OWNER
REPO_OWNER="${REPO_OWNER:-luminor-project}"

read -rp "Repo name: " REPO_NAME
if [[ -z "$REPO_NAME" ]]; then
    echo "Error: Repo name is required" >&2
    exit 1
fi

# --- GitHub PAT (per-target, for orchestrator runtime) ---

echo ""
echo "  GitHub PAT — fine-grained, for the orchestrator to interact with this repo."
echo ""
echo "  The orchestrator uses this PAT to clone the repo, post PR comments,"
echo "  and create issues from Slack."
echo "  Create one at: https://github.com/settings/personal-access-tokens/new"
echo ""
echo "  Settings:"
echo "    - Token name:       productbuilder-${REPO_NAME}"
echo "    - Expiration:       90 days (or longer; you'll rotate later)"
echo "    - Resource owner:   ${REPO_OWNER}"
echo "    - Repository access: Only select repositories → ${REPO_NAME}"
echo "    - Permissions (Repository):"
echo "        Contents:       Read        (clone the repo)"
echo "        Issues:         Read+Write  (create issues, post comments)"
echo "        Pull requests:  Read+Write  (post preview URL comments)"
echo "        Metadata:       Read        (required by default)"
echo ""
read -rp "GitHub PAT (github_pat_...): " GITHUB_PAT
if [[ -z "$GITHUB_PAT" ]]; then
    echo "Error: GitHub PAT is required" >&2
    exit 1
fi

# --- Fireworks API key (for OpenCode GitHub Actions) ---

echo ""
echo "  Fireworks API key — for the OpenCode GitHub Actions workflow."
echo ""
echo "  This key is set as the FIREWORKS_API_KEY secret on the target repo"
echo "  so that the .github/workflows/opencode.yml action can call the Fireworks API."
echo "  Get one at: https://fireworks.ai/account/api-keys"
echo ""
echo "  You can reuse the same key across multiple target repos."
echo ""
read -rp "Fireworks API key (fw-...): " FIREWORKS_API_KEY
if [[ -z "$FIREWORKS_API_KEY" ]]; then
    echo "Error: Fireworks API key is required" >&2
    exit 1
fi

# --- Slack Integration (optional) ---

echo ""
echo "  Slack Integration — mirror GitHub activity to Slack channels."
echo ""
echo "  This creates Slack threads for Issues and PRs with real-time updates."
echo "  See docs/SLACK_INTEGRATION.md for full setup instructions."
echo ""

read -rp "Enable Slack integration? [y/N]: " ENABLE_SLACK
ENABLE_SLACK="${ENABLE_SLACK:-n}"

if [[ "$ENABLE_SLACK" =~ ^[Yy]$ ]]; then
    echo ""
    echo "  Slack Bot Token — required to post messages to channels."
    echo ""
    echo "  Create a Slack app at: https://api.slack.com/apps"
    echo "  Required scopes: chat:write, chat:write.public, reactions:write,"
    echo "                    channels:read, app_mentions:read, users:read"
    echo "  Install the app to your workspace, then copy the Bot User OAuth Token."
    echo ""
    read -rp "Slack Bot Token (xoxb-...): " SLACK_BOT_TOKEN
    if [[ -z "$SLACK_BOT_TOKEN" ]]; then
        echo "Warning: Slack Bot Token not provided. Skipping Slack integration." >&2
        ENABLE_SLACK="n"
    fi
    
    if [[ "$ENABLE_SLACK" =~ ^[Yy]$ ]]; then
        echo ""
        echo "  Slack Channel — where notifications will be posted."
        echo ""
        echo "  IMPORTANT: You must manually create this channel in Slack first!"
        echo "  REQUIRED naming: #productbuilding-{repo-name}"
        echo "  (The system uses this convention to match channels to repos for issue creation.)"
        echo "  Example: For repo 'webapp', create channel #productbuilding-webapp"
        echo ""
        read -rp "Slack channel name (e.g., #productbuilding-${REPO_NAME}): " SLACK_CHANNEL
        if [[ -z "$SLACK_CHANNEL" ]]; then
            SLACK_CHANNEL="#productbuilding-${REPO_NAME}"
            echo "Using default: $SLACK_CHANNEL"
        fi
        
        # Validate channel name format
        if [[ ! "$SLACK_CHANNEL" =~ ^# ]]; then
            SLACK_CHANNEL="#${SLACK_CHANNEL}"
            echo "Added # prefix: $SLACK_CHANNEL"
        fi
        
        echo ""
        echo "✅ Slack integration configured for channel: $SLACK_CHANNEL"
        echo "   Remember to invite the bot to this channel after deployment!"
        echo "   Run: /invite @ProductBuilder Bot"
    fi
else
    echo "Skipping Slack integration (can be enabled later)"
fi

# --- Local clone path (optional, for scaffolding) ---

echo ""
echo "  Local clone path — the local checkout of ${REPO_OWNER}/${REPO_NAME}."
echo "  If provided, the script will scaffold .productbuilding/, AGENTS.md,"
echo "  and .github/workflows/opencode.yml in that directory."
echo "  Leave empty to skip scaffolding."
echo ""
read -rp "Local repo clone path: " TARGET_REPO_PATH
if [[ -n "$TARGET_REPO_PATH" && ! -d "$TARGET_REPO_PATH" ]]; then
    echo "Error: Directory does not exist: $TARGET_REPO_PATH" >&2
    exit 1
fi

WEBHOOK_SECRET=$(openssl rand -hex 32)
echo ""
echo "Generated webhook secret: $WEBHOOK_SECRET"

# --- Orchestrator-side: register target in tfvars ---

if [[ ! -f "$TFVARS_FILE" ]]; then
    echo 'targets = {' > "$TFVARS_FILE"
    echo '}' >> "$TFVARS_FILE"
fi

if [[ "$ENABLE_SLACK" =~ ^[Yy]$ ]]; then
  ENTRY="  \"$REPO_NAME\" = {
    repo_owner        = \"$REPO_OWNER\"
    repo_name         = \"$REPO_NAME\"
    github_pat        = \"$GITHUB_PAT\"
    webhook_secret    = \"$WEBHOOK_SECRET\"
    fireworks_api_key = \"$FIREWORKS_API_KEY\"
    slack_channel     = \"$SLACK_CHANNEL\"
    slack_bot_token   = \"$SLACK_BOT_TOKEN\"
  }"
else
  ENTRY="  \"$REPO_NAME\" = {
    repo_owner        = \"$REPO_OWNER\"
    repo_name         = \"$REPO_NAME\"
    github_pat        = \"$GITHUB_PAT\"
    webhook_secret    = \"$WEBHOOK_SECRET\"
    fireworks_api_key = \"$FIREWORKS_API_KEY\"
  }"
fi

# Remove trailing } , add the entry, re-add }
sed -i.bak '$ d' "$TFVARS_FILE"
echo "$ENTRY" >> "$TFVARS_FILE"
echo "}" >> "$TFVARS_FILE"
rm -f "$TFVARS_FILE.bak"

echo ""
echo "Appended to $TFVARS_FILE"

# --- Target repo side: scaffold productbuilding files ---

if [[ -n "$TARGET_REPO_PATH" ]]; then
    echo ""
    echo "Scaffolding target repo at $TARGET_REPO_PATH..."

    # .productbuilding/preview/config.yml
    mkdir -p "$TARGET_REPO_PATH/.productbuilding/preview"
    if [[ ! -f "$TARGET_REPO_PATH/.productbuilding/preview/config.yml" ]]; then
        cat > "$TARGET_REPO_PATH/.productbuilding/preview/config.yml" <<'CONFIGEOF'
version: 1

compose:
  file: .productbuilding/preview/docker-compose.yml
  service: app

runtime:
  internal_port: 8080
  healthcheck_path: /healthz
  startup_timeout_seconds: 300

# database:
#   migrate_command: <your migration command here>

# Optional: configure log access (defaults to docker compose logs from the main service)
# logging:
#   service: app           # Which compose service has the logs
#   type: docker           # "docker" for stdout/stderr (default), "file" for file-based logs
#   path: /var/log/*.log   # Required when type="file" - path inside container

# Optional: add a note that will be shown in PR comments (e.g., test credentials, important info)
# user_facing_note: "Test login: admin / secret"

# Optional: run commands after preview is deployed and healthy (e.g., seed data)
# post_deploy_commands:
#   - service: app           # Which compose service to run in (default: compose.service)
#     command: echo "Hello" # Command to execute
#     description: Say hi   # Description for logs (optional)
CONFIGEOF
        echo "  Created .productbuilding/preview/config.yml"
    else
        echo "  Skipped .productbuilding/preview/config.yml (already exists)"
    fi

    # .productbuilding/preview/docker-compose.yml
    if [[ ! -f "$TARGET_REPO_PATH/.productbuilding/preview/docker-compose.yml" ]]; then
        cat > "$TARGET_REPO_PATH/.productbuilding/preview/docker-compose.yml" <<'COMPOSEEOF'
# Preview Compose file — production-oriented (no hot reload, no host mounts).
# The orchestrator will generate an override with Traefik labels and network config.

services:
  app:
    build:
      context: ../..
      dockerfile: Dockerfile
    # environment:
    #   - DATABASE_URL=postgres://...
    # depends_on:
    #   db:
    #     condition: service_healthy

  # db:
  #   image: postgres:17
  #   environment:
  #     POSTGRES_DB: app
  #     POSTGRES_USER: app
  #     POSTGRES_PASSWORD: preview
  #   healthcheck:
  #     test: ["CMD-SHELL", "pg_isready -U app"]
  #     interval: 5s
  #     timeout: 3s
  #     retries: 5
COMPOSEEOF
        echo "  Created .productbuilding/preview/docker-compose.yml"
    else
        echo "  Skipped .productbuilding/preview/docker-compose.yml (already exists)"
    fi

    # .github/workflows/opencode.yml
    mkdir -p "$TARGET_REPO_PATH/.github/workflows"
    if [[ ! -f "$TARGET_REPO_PATH/.github/workflows/opencode.yml" ]]; then
        cat > "$TARGET_REPO_PATH/.github/workflows/opencode.yml" <<'WORKFLOWEOF'
name: OpenCode

permissions:
  contents: write
  pull-requests: write
  issues: write
  id-token: write

on:
  issue_comment:
    types: [created]
  pull_request_review_comment:
    types: [created]
  pull_request_review:
    types: [submitted]

jobs:
  opencode:
    if: |
      contains(github.event.comment.body, '/opencode') &&
      !endsWith(github.event.comment.user.login, '[bot]')
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: anomalyco/opencode/github@latest
        env:
          FIREWORKS_API_KEY: ${{ secrets.FIREWORKS_API_KEY }}
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          model: fireworks-ai/accounts/fireworks/models/kimi-k2p5
WORKFLOWEOF
        echo "  Created .github/workflows/opencode.yml"
    else
        echo "  Skipped .github/workflows/opencode.yml (already exists)"
    fi

    # AGENTS.md
    if [[ ! -f "$TARGET_REPO_PATH/AGENTS.md" ]]; then
        cat > "$TARGET_REPO_PATH/AGENTS.md" <<AGENTSEOF
# AGENTS.md — Project Guide for AI Coding Agents

## Project Overview

<!-- Describe what this project does, its purpose, and key features. -->

## Architecture

<!-- Describe the project structure, key directories, and architectural patterns. -->

## Development

<!-- How to build, run, and test the project locally. -->

## Coding Standards

<!-- Language-specific conventions, formatting, naming, etc. -->

## Important Rules

<!-- Non-negotiable constraints AI agents should always follow. -->

## AI Integration

This project uses OpenCode with FireworksAI (Kimi K2.5).
Trigger with "/opencode" in GitHub issues and pull requests.
AGENTSEOF
        echo "  Created AGENTS.md"
    else
        echo "  Skipped AGENTS.md (already exists)"
    fi
fi

echo ""
echo "Next steps:"
echo "  1. mise run secrets-encrypt && mise run infra-apply"
echo "  2. Install the OpenCode GitHub App on the repo:"
echo "     https://github.com/apps/opencode-agent"
if [[ "$ENABLE_SLACK" =~ ^[Yy]$ ]]; then
    echo ""
    echo "  📱 Slack Integration Setup:"
    echo "     a. Create Slack channel: $SLACK_CHANNEL"
    echo "     b. Invite bot to channel: /invite @ProductBuilder Bot"
    echo "     c. Configure GitHub webhook (see docs/SLACK_INTEGRATION.md)"
    echo "     d. Test: Create an Issue and verify Slack notification"
    echo ""
    echo "  📚 Documentation:"
    echo "     Full guide: docs/SLACK_INTEGRATION.md"
    echo "     Verification checklist: docs/SLACK_VERIFICATION.md"
fi
if [[ -n "$TARGET_REPO_PATH" ]]; then
    echo "  3. Review and customize the scaffolded files, then commit and push"
else
    echo "  3. Add .productbuilding/preview/ to the repo (see docs)"
    echo "  4. Add .github/workflows/opencode.yml to the repo"
    echo "  5. Add AGENTS.md to the repo"
fi
