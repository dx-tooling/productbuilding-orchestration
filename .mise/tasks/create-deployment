mise run ssh -- "cd /opt/orchestrator/repo && docker compose up -d orchestrator"

# ── Health check ──────────────────────────────────────────────────────

echo "==> Waiting for health check..."
DOMAIN=$(mise run ssh -- "grep '^PREVIEW_DOMAIN=' /opt/orchestrator/repo/.env | cut -d= -f2" 2>/dev/null)
