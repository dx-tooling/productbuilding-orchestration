#!/usr/bin/env bash
#MISE description="Scaffold a new deployment repo"
set -euo pipefail

# ── Argument parsing ────────────────────────────────────────────────

NAME="${1:-}"
NON_INTERACTIVE=false
for arg in "$@"; do
    if [[ "$arg" == "--non-interactive" ]]; then
        NON_INTERACTIVE=true
    fi
done

if [[ -z "$NAME" ]]; then
    echo "Usage: mise run create-deployment <name> [--non-interactive]"
    echo ""
    echo "Creates ../productbuilding-deployment-<name>/ with all infrastructure,"
    echo "secrets, and operational tasks needed to run your own deployment."
    echo ""
    echo "Options:"
    echo "  --non-interactive   Scaffold with placeholders only (no prompts, no bootstrap)"
    exit 1
fi

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
ORCH_DIRNAME="$(basename "$PROJECT_DIR")"
DEPLOY_DIR="$(dirname "$PROJECT_DIR")/productbuilding-deployment-${NAME}"

if [[ -d "$DEPLOY_DIR" ]]; then
    echo "Error: $DEPLOY_DIR already exists" >&2
    exit 1
fi

# ── Prerequisite checks ────────────────────────────────────────────

if [[ "$NON_INTERACTIVE" == false ]]; then
    MISSING_TOOLS=()
    for cmd in age age-keygen tofu aws openssl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            MISSING_TOOLS+=("$cmd")
        fi
    done
    if [[ ${#MISSING_TOOLS[@]} -gt 0 ]]; then
        echo "Error: Missing required tools: ${MISSING_TOOLS[*]}" >&2
        echo ""
        echo "Install with:"
        echo "  brew install age opentofu awscli openssl"
        exit 1
    fi
fi

# ── Helper functions ────────────────────────────────────────────────

source "$(dirname "$0")/../lib/create-deployment-helpers.sh"

# ── Interactive collection ──────────────────────────────────────────

# Defaults for non-interactive mode
CFG_AWS_ACCESS_KEY_ID=""
CFG_AWS_SECRET_ACCESS_KEY=""
CFG_AWS_REGION="eu-central-1"
CFG_GITHUB_PAT_MGMT=""
CFG_ORCH_GITHUB_ORG="dx-tooling"
CFG_PREVIEW_DOMAIN=""
CFG_ACME_EMAIL=""
CFG_PROJECT_PREFIX="productbuilder"
CFG_INSTANCE_TYPE="t3.xlarge"
CFG_SSH_PUBLIC_KEY=""
CFG_SLACK_WORKSPACE=""
CFG_SLACK_SIGNING_SECRET=""
CFG_LLM_API_KEY=""
CFG_AWS_ACCOUNT_ID=""

if [[ "$NON_INTERACTIVE" == false ]]; then

echo "Creating deployment repo: productbuilding-deployment-${NAME}"
echo "Orchestration repo: $ORCH_DIRNAME"

# ── 1. AWS ──

section_header "AWS Configuration"
echo "  Credentials for provisioning infrastructure (EC2, Route53, Secrets Manager)"
echo "  and the Terraform state backend (S3 + DynamoDB)."
echo ""
echo "  Create an IAM user with AdministratorAccess, or a policy covering:"
echo "  EC2, Route53, S3, DynamoDB, IAM, Secrets Manager, VPC."
echo ""

read -rp "  AWS Access Key ID: " CFG_AWS_ACCESS_KEY_ID
while ! validate_aws_key_id "$CFG_AWS_ACCESS_KEY_ID"; do
    echo "  (must start with AKIA and be 20 characters)"
    read -rp "  AWS Access Key ID: " CFG_AWS_ACCESS_KEY_ID
done

read -rp "  AWS Secret Access Key: " CFG_AWS_SECRET_ACCESS_KEY
while [[ -z "$CFG_AWS_SECRET_ACCESS_KEY" ]]; do
    echo "  (required)"
    read -rp "  AWS Secret Access Key: " CFG_AWS_SECRET_ACCESS_KEY
done

read -rp "  AWS Region [eu-central-1]: " CFG_AWS_REGION
CFG_AWS_REGION="${CFG_AWS_REGION:-eu-central-1}"

echo ""
echo "  Verifying AWS credentials..."
if CFG_AWS_ACCOUNT_ID=$(AWS_ACCESS_KEY_ID="$CFG_AWS_ACCESS_KEY_ID" \
    AWS_SECRET_ACCESS_KEY="$CFG_AWS_SECRET_ACCESS_KEY" \
    AWS_DEFAULT_REGION="$CFG_AWS_REGION" \
    aws sts get-caller-identity --query Account --output text 2>/dev/null); then
    echo "  Verified: AWS account $CFG_AWS_ACCOUNT_ID"
else
    echo "  ERROR: AWS credentials are invalid." >&2
    echo "  Please check and try again." >&2
    exit 1
fi

# ── 2. GitHub ──

section_header "GitHub Configuration"
echo "  The orchestration PAT is used by cloud-init on the EC2 host to clone"
echo "  the productbuilding-orchestration repo. It does NOT manage per-target"
echo "  webhooks or Actions secrets — those are created by the orchestrator"
echo "  process itself, using each target's own per-target PAT, so there is"
echo "  no requirement that all targets live in one GitHub org."
echo ""
echo "  Create a fine-grained PAT at: https://github.com/settings/personal-access-tokens/new"
echo "  Resource owner: the org hosting productbuilding-orchestration"
echo "  Repository access: only the productbuilding-orchestration repo"
echo "  Repository permissions: Contents: Read"
echo ""

read -rp "  Orchestration repo PAT: " CFG_GITHUB_PAT_MGMT
while [[ -z "$CFG_GITHUB_PAT_MGMT" ]]; do
    echo "  (required)"
    read -rp "  Orchestration repo PAT: " CFG_GITHUB_PAT_MGMT
done

echo ""
echo "  The orchestration repo org — where productbuilding-orchestration lives."
read -rp "  Orchestration GitHub org [dx-tooling]: " CFG_ORCH_GITHUB_ORG
CFG_ORCH_GITHUB_ORG="${CFG_ORCH_GITHUB_ORG:-dx-tooling}"

# ── 3. Domain ──

section_header "Domain & Certificates"
echo "  A Route53 hosted zone and wildcard DNS record will be created."
echo "  Preview environments will be accessible at:"
echo "    {repo}-pr-{N}.{domain}"
echo ""
echo "  After provisioning, you'll need to delegate DNS from your registrar."
echo ""

read -rp "  Preview domain (e.g., productbuilder.mycompany.net): " CFG_PREVIEW_DOMAIN
while ! validate_domain "$CFG_PREVIEW_DOMAIN"; do
    echo "  (must be a valid domain like productbuilder.mycompany.net)"
    read -rp "  Preview domain: " CFG_PREVIEW_DOMAIN
done

ACME_DEFAULT=$(derive_acme_email "$CFG_PREVIEW_DOMAIN")
echo ""
echo "  Email for Let's Encrypt certificate registration."
read -rp "  ACME email [$ACME_DEFAULT]: " CFG_ACME_EMAIL
CFG_ACME_EMAIL="${CFG_ACME_EMAIL:-$ACME_DEFAULT}"

# ── 4. Infrastructure ──

section_header "Infrastructure"
echo "  Resource naming prefix and EC2 instance configuration."
echo ""

read -rp "  Project prefix [productbuilder]: " CFG_PROJECT_PREFIX
CFG_PROJECT_PREFIX="${CFG_PROJECT_PREFIX:-productbuilder}"

read -rp "  EC2 instance type [t3.xlarge]: " CFG_INSTANCE_TYPE
CFG_INSTANCE_TYPE="${CFG_INSTANCE_TYPE:-t3.xlarge}"

echo ""
echo "  SSH public key for EC2 instance access."
CFG_SSH_PUBLIC_KEY=$(detect_ssh_key)
while ! validate_ssh_key_format "$CFG_SSH_PUBLIC_KEY"; do
    echo "  (must start with ssh-rsa, ssh-ed25519, etc.)"
    read -rp "  SSH public key: " CFG_SSH_PUBLIC_KEY
done

# ── 5. Slack (optional) ──

section_header "Slack Integration (optional)"
echo "  Enables webhook request verification and deep links to your Slack workspace."
echo ""

if prompt_yesno "Enable Slack integration?" "n"; then
    echo ""
    echo "  Your Slack workspace subdomain (e.g., 'myteam' from myteam.slack.com)."
    read -rp "  Slack workspace: " CFG_SLACK_WORKSPACE
    echo ""
    echo "  The signing secret from your Slack app's Basic Information page."
    echo "  Used to verify that webhook requests actually come from Slack."
    read -rp "  Slack signing secret: " CFG_SLACK_SIGNING_SECRET
fi

# ── 6. AI Integration (optional) ──

section_header "AI Integration (optional)"
echo "  Anthropic API key for the orchestration agent."
echo "  Recommended key type: standard Anthropic API key for Messages API."
echo "  You can also configure this post-deploy via 'mise run switch-llm-provider'."
echo ""

read -rp "  LLM API key (leave empty to skip): " CFG_LLM_API_KEY

# ── Summary ──

section_header "Summary"
echo "  Deployment:     productbuilding-deployment-${NAME}"
echo "  Deploy dir:     $DEPLOY_DIR"
echo ""
echo "  AWS Account:    $CFG_AWS_ACCOUNT_ID"
echo "  AWS Region:     $CFG_AWS_REGION"
echo "  AWS Key:        $(mask_secret "$CFG_AWS_ACCESS_KEY_ID")"
echo ""
echo "  Orch Org:       $CFG_ORCH_GITHUB_ORG"
echo "  Orch Repo PAT:  $(mask_secret "$CFG_GITHUB_PAT_MGMT")"
echo ""
echo "  Preview Domain: $CFG_PREVIEW_DOMAIN"
echo "  ACME Email:     $CFG_ACME_EMAIL"
echo "  Project Prefix: $CFG_PROJECT_PREFIX"
echo "  Instance Type:  $CFG_INSTANCE_TYPE"
echo "  SSH Key:        ${CFG_SSH_PUBLIC_KEY:0:30}..."
echo ""
if [[ -n "$CFG_SLACK_WORKSPACE" ]]; then
    echo "  Slack:          $CFG_SLACK_WORKSPACE"
fi
if [[ -n "$CFG_LLM_API_KEY" ]]; then
    echo "  LLM Key:        $(mask_secret "$CFG_LLM_API_KEY")"
fi
echo ""

if ! prompt_yesno "Proceed?" "y"; then
    echo "Aborted."
    exit 0
fi

else
    echo "Creating deployment repo at $DEPLOY_DIR"
    echo "Orchestration repo: $ORCH_DIRNAME"
    echo ""
fi

# ══════════════════════════════════════════════════════════════════════
# SCAFFOLDING — Generate all files
# ══════════════════════════════════════════════════════════════════════

# ── Create directory structure ──────────────────────────────────────
mkdir -p "$DEPLOY_DIR"/{infrastructure-mgmt/{main,bootstrap},secrets,.mise/{tasks,lib},docs}

# ── Root files ──────────────────────────────────────────────────────

cat > "$DEPLOY_DIR/mise.toml" <<EOF
# Deployment: ${NAME}
# Orchestration repo expected at: ../${ORCH_DIRNAME}/

[task_config]
includes = [".mise/tasks"]
EOF

cat > "$DEPLOY_DIR/.gitignore" <<'EOF'
secrets.yaml
secrets/.key
.env

# macOS
.DS_Store
**/.DS_Store

# OpenTofu
infrastructure-mgmt/bootstrap/terraform.tfstate
infrastructure-mgmt/bootstrap/terraform.tfstate.backup
infrastructure-mgmt/bootstrap/.terraform/
infrastructure-mgmt/main/.terraform/
infrastructure-mgmt/main/targets.auto.tfvars
infrastructure-mgmt/main/terraform.tfvars
**/.terraform.lock.hcl

.claude/
EOF

cat > "$DEPLOY_DIR/README.md" <<EOF
# ProductBuilding Deployment: ${NAME}

Private deployment configuration for the [productbuilding-orchestration](../${ORCH_DIRNAME}/) platform.

This repo contains infrastructure definitions, secrets, and operational tasks for this specific deployment. The generic orchestration code lives in the core repo at \`../${ORCH_DIRNAME}/\`.

## Prerequisites

- [mise](https://mise.jdx.dev/)
- [OpenTofu](https://opentofu.org/) (\`brew install opentofu\`)
- [AWS CLI](https://aws.amazon.com/cli/)
- [age](https://github.com/FiloSottile/age) (\`brew install age\`)
- The orchestration repo cloned alongside this repo at \`../${ORCH_DIRNAME}/\`

## Setup from scratch

### 1. Generate age keypair

\`\`\`bash
age-keygen -o secrets/.key
# Copy the printed public key (age1...) into secrets/public-key.txt
# Store the secret key (contents of secrets/.key) somewhere safe (e.g. 1Password)
\`\`\`

### 2. Create secrets

Create \`secrets.yaml\` at the repo root:
\`\`\`yaml
access_key_id: <AWS_ACCESS_KEY_ID>
secret_access_key: <AWS_SECRET_ACCESS_KEY>
github_pat_mgmt: <GITHUB_MANAGEMENT_PAT>
\`\`\`

Create \`infrastructure-mgmt/main/terraform.tfvars\`:
\`\`\`hcl
github_mgmt_pat = "<same GitHub PAT>"
ssh_public_key  = "<your SSH public key>"
# Optional:
# slack_signing_secret = "..."
# llm_api_key          = "..."
\`\`\`

### 3. Bootstrap state backend (one-time)

\`\`\`bash
eval "\$(.mise/lib/load-secrets)"
cd infrastructure-mgmt/bootstrap
tofu init && tofu apply
\`\`\`

Note the outputs and fill in \`infrastructure-mgmt/main/backend.tf\` with the S3 bucket name and DynamoDB table name.

### 4. Deploy infrastructure

\`\`\`bash
mise run infra-apply
\`\`\`

### 5. DNS delegation

Delegate your preview subdomain to the Route53 nameservers shown in \`mise run infra-output\`.

### 6. Encrypt and commit secrets

\`\`\`bash
mise run secrets-encrypt
git add secrets/*.enc
git commit -m "Add encrypted secrets"
\`\`\`

### 7. Deploy orchestrator

\`\`\`bash
mise run deploy
\`\`\`

## Ongoing operations

| Task | What it does |
|------|--------------|
| \`mise run deploy\` | SSH deploy: git pull, refresh secrets, rebuild, health check |
| \`mise run ssh\` | SSH into orchestrator instance |
| \`mise run infra-plan\` | OpenTofu plan |
| \`mise run infra-apply\` | OpenTofu apply |
| \`mise run instance-start\` | Start EC2 instance |
| \`mise run instance-stop\` | Stop EC2 instance (cost savings) |
| \`mise run instance-status\` | Check EC2 instance state |
| \`mise run onboard-target\` | Interactive: register new target repo |
| \`mise run slack-setup\` | Print Slack app setup checklist and URLs |
| \`mise run switch-llm-provider\` | Interactive: change LLM provider, model, API key |
| \`mise run secrets-decrypt\` | Decrypt secrets (requires secrets/.key) |
| \`mise run secrets-encrypt\` | Encrypt secrets (public key only) |
| \`mise run preview-logs <owner> <repo> <pr>\` | View preview application logs |

For app development tasks (\`app-build\`, \`app-tests\`, \`app-dev\`, etc.), work from the orchestration repo at \`../${ORCH_DIRNAME}/\`.
EOF

# ── decrypt-secrets.sh ──────────────────────────────────────────────

cat > "$DEPLOY_DIR/decrypt-secrets.sh" <<'SCRIPTEOF'
#!/usr/bin/env bash
# Decrypt secrets/*.enc into their plaintext locations using the secret key in secrets/.key.
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRETS_DIR="${REPO_ROOT}/secrets"
KEY_FILE="${SECRETS_DIR}/.key"

if [ ! -f "$KEY_FILE" ]; then
    echo "Error: Secret key not found at ${KEY_FILE}" >&2
    echo "Paste your age secret key into that file (see secrets/README.md)." >&2
    exit 1
fi

if ! command -v age >/dev/null 2>&1; then
    echo "Error: 'age' is not installed (brew install age)." >&2
    exit 1
fi

decrypt_one() {
    local enc_file="$1"
    local out_file="$2"
    if [ ! -f "$enc_file" ]; then
        echo "  (skip: $enc_file not found)"
        return 0
    fi
    local out_dir
    out_dir=$(dirname "$out_file")
    mkdir -p "$out_dir"
    if age -d -i "$KEY_FILE" -o "$out_file" "$enc_file" 2>/dev/null; then
        chmod 600 "$out_file"
        echo "  decrypted: $(basename "$enc_file") -> ${out_file#"$REPO_ROOT"/}"
    else
        echo "  (failed: $enc_file)" >&2
        rm -f "$out_file"
        return 1
    fi
}

echo "Decrypting secrets..."
decrypt_one "${SECRETS_DIR}/secrets.yaml.enc" "${REPO_ROOT}/secrets.yaml"
decrypt_one "${SECRETS_DIR}/terraform.tfvars.enc" "${REPO_ROOT}/infrastructure-mgmt/main/terraform.tfvars"
decrypt_one "${SECRETS_DIR}/targets.auto.tfvars.enc" "${REPO_ROOT}/infrastructure-mgmt/main/targets.auto.tfvars"
echo "Done."
SCRIPTEOF
chmod +x "$DEPLOY_DIR/decrypt-secrets.sh"

# ── encrypt-secrets.sh ──────────────────────────────────────────────

cat > "$DEPLOY_DIR/encrypt-secrets.sh" <<'SCRIPTEOF'
#!/usr/bin/env bash
# Encrypt plaintext secret files into secrets/*.enc using the public key.
# No secret key needed — only the public key (committed) is used.
set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRETS_DIR="${REPO_ROOT}/secrets"
PUBLIC_KEY_FILE="${SECRETS_DIR}/public-key.txt"

if [ ! -f "$PUBLIC_KEY_FILE" ]; then
    echo "Error: Public key not found at ${PUBLIC_KEY_FILE}" >&2
    exit 1
fi

PUBLIC_KEY=$(grep -E '^age1' "$PUBLIC_KEY_FILE" | head -1)
if [ -z "$PUBLIC_KEY" ]; then
    echo "Error: No age public key (age1...) found in ${PUBLIC_KEY_FILE}" >&2
    exit 1
fi

if ! command -v age >/dev/null 2>&1; then
    echo "Error: 'age' is not installed (brew install age)." >&2
    exit 1
fi

encrypt_one() {
    local src_file="$1"
    local enc_name="$2"
    local enc_file="${SECRETS_DIR}/${enc_name}"
    if [ ! -f "$src_file" ]; then
        echo "  (skip: $src_file not found)"
        return 0
    fi
    if age -e -r "$PUBLIC_KEY" -o "$enc_file" "$src_file" 2>/dev/null; then
        echo "  encrypted: $(basename "$src_file") -> secrets/$enc_name"
    else
        echo "  (failed: $src_file)" >&2
        return 1
    fi
}

echo "Encrypting secrets (using public key only)..."
encrypt_one "${REPO_ROOT}/secrets.yaml" "secrets.yaml.enc"
encrypt_one "${REPO_ROOT}/infrastructure-mgmt/main/terraform.tfvars" "terraform.tfvars.enc"
encrypt_one "${REPO_ROOT}/infrastructure-mgmt/main/targets.auto.tfvars" "targets.auto.tfvars.enc"
echo "Done. Commit secrets/*.enc; never commit secrets/.key or decrypted plaintext files."
SCRIPTEOF
chmod +x "$DEPLOY_DIR/encrypt-secrets.sh"

# ── secrets/ ────────────────────────────────────────────────────────

cat > "$DEPLOY_DIR/secrets/README.md" <<'EOF'
# Encrypted secrets (asymmetric)

Secret files are stored here **encrypted** so they can be committed to the repo safely. We use [age](https://github.com/FiloSottile/age) with **asymmetric** encryption:

- **Encryption** uses the **public key** in `public-key.txt` (committed). Anyone with the repo can encrypt.
- **Decryption** requires the **secret key**, pasted into `.key` (gitignored).

## Setup (first time or new machine)

1. Install age: `brew install age` (macOS) or see [age releases](https://github.com/FiloSottile/age/releases).
2. Get the age secret key and paste it into `secrets/.key`:
   ```bash
   # The key starts with AGE-SECRET-KEY-...
   pbpaste > secrets/.key   # macOS
   ```
3. From the **repo root**, decrypt all secrets:
   ```bash
   ./decrypt-secrets.sh
   ```

This produces the gitignored plaintext files used by mise tasks and OpenTofu.

## Encrypted files (committed)

| Encrypted file | Decrypts to | Purpose |
|----------------|-------------|---------|
| `secrets.yaml.enc` | `secrets.yaml` | AWS credentials, GitHub management PAT |
| `terraform.tfvars.enc` | `infrastructure-mgmt/main/terraform.tfvars` | OpenTofu variables (mgmt PAT, SSH key) |
| `targets.auto.tfvars.enc` | `infrastructure-mgmt/main/targets.auto.tfvars` | Per-target-repo credentials |

## Encrypting (after changing secrets)

```bash
./encrypt-secrets.sh
# Then commit the updated secrets/*.enc files
```

## Bootstrap: generating a new keypair

```bash
age-keygen -o secrets/.key
# Copy the printed public key into secrets/public-key.txt
# Store the secret key (contents of secrets/.key) somewhere safe
```
EOF

