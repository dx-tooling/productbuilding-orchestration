# --- deploy ---
cat > "$DEPLOY_DIR/.mise/tasks/deploy" <<'EOF'
#!/usr/bin/env bash
#MISE description="Deploy latest code to the EC2 instance"
set -euo pipefail

echo "==> Loading local AWS credentials for infra outputs..."
eval "$($(dirname "$0")/../lib/load-secrets)"

echo "==> Syncing infrastructure values into server .env..."
INFRA_DIR="$(dirname "$0")/../../infrastructure-mgmt/main"
ZONE_ID=$(cd "$INFRA_DIR" && tofu output -raw route53_zone_id 2>/dev/null || true)
DOMAIN=$(cd "$INFRA_DIR" && tofu output -raw preview_domain 2>/dev/null || true)

if [[ -n "$ZONE_ID" || -n "$DOMAIN" ]]; then
  mise run ssh -- "sudo bash -c '
    ENV_FILE=/opt/orchestrator/repo/.env
    [[ -n \"$ZONE_ID\" ]] && sed -i /^AWS_HOSTED_ZONE_ID=/d \"\$ENV_FILE\" && echo \"AWS_HOSTED_ZONE_ID=$ZONE_ID\" >> \"\$ENV_FILE\"
    [[ -n \"$DOMAIN\" ]] && sed -i /^PREVIEW_DOMAIN=/d \"\$ENV_FILE\" && echo \"PREVIEW_DOMAIN=$DOMAIN\" >> \"\$ENV_FILE\"
    echo \"Synced infra values in \$ENV_FILE\"
  '"
else
  echo "Warning: Could not read infra outputs, skipping .env infra sync."
fi

echo "==> Pulling latest code on server..."
mise run ssh -- "cd /opt/orchestrator/repo && git pull"

echo "==> Refreshing target configs from Secrets Manager..."
mise run ssh -- 'sudo bash -c "
  REGION=\$(grep AWS_REGION /opt/orchestrator/repo/.env | cut -d= -f2)
  PREFIX=\$(grep PROJECT_PREFIX /opt/orchestrator/repo/.env | cut -d= -f2)
  TARGETS=\"[]\"
  for name in \$(aws secretsmanager list-secrets --region \"\$REGION\" \
    --filters \"Key=name,Values=\$PREFIX/targets/\" --query \"SecretList[].Name\" --output text); do
    VAL=\$(aws secretsmanager get-secret-value --region \"\$REGION\" \
      --secret-id \"\$name\" --query SecretString --output text)
    TARGETS=\$(echo \"\$TARGETS\" | jq --argjson item \"\$VAL\" \". + [\\\$item]\")
  done
  echo \"\$TARGETS\" > /opt/orchestrator/targets.json
  chmod 644 /opt/orchestrator/targets.json
  echo \"Loaded \$(echo \"\$TARGETS\" | jq length) target(s)\"
"'

echo "==> Refreshing Slack signing secret..."
mise run ssh -- 'sudo bash -c "
  REGION=\$(grep AWS_REGION /opt/orchestrator/repo/.env | cut -d= -f2)
  PREFIX=\$(grep PROJECT_PREFIX /opt/orchestrator/repo/.env | cut -d= -f2)
  SECRET=\$(aws secretsmanager get-secret-value --region \"\$REGION\" \
    --secret-id \"\$PREFIX/slack-signing-secret\" \
    --query SecretString --output text 2>/dev/null || echo \"\")
  # Remove old value (if any) and append current
  sed -i /^SLACK_SIGNING_SECRET=/d /opt/orchestrator/repo/.env
  if [ -n \"\$SECRET\" ]; then
    echo \"SLACK_SIGNING_SECRET=\$SECRET\" >> /opt/orchestrator/repo/.env
    echo \"Slack signing secret loaded\"
  else
    echo \"No Slack signing secret configured (skipped)\"
  fi
"'

echo "==> Refreshing LLM API key..."
mise run ssh -- 'sudo bash -c "
  REGION=\$(grep AWS_REGION /opt/orchestrator/repo/.env | cut -d= -f2)
  PREFIX=\$(grep PROJECT_PREFIX /opt/orchestrator/repo/.env | cut -d= -f2)
  SECRET=\$(aws secretsmanager get-secret-value --region \"\$REGION\" \
    --secret-id \"\$PREFIX/llm-api-key\" \
    --query SecretString --output text 2>/dev/null || echo \"\")
  sed -i /^LLM_API_KEY=/d /opt/orchestrator/repo/.env
  sed -i /^LLM_PROVIDER=/d /opt/orchestrator/repo/.env
  sed -i /^LLM_MODEL=/d /opt/orchestrator/repo/.env
  sed -i /^LLM_BASE_URL=/d /opt/orchestrator/repo/.env
  if [ -n \"\$SECRET\" ]; then
    echo \"LLM_API_KEY=\$SECRET\" >> /opt/orchestrator/repo/.env
    # Anthropic is the deployment default and should not depend on stale env.
    echo \"LLM_PROVIDER=anthropic\" >> /opt/orchestrator/repo/.env
    echo \"LLM_MODEL=claude-opus-4-6\" >> /opt/orchestrator/repo/.env
    echo \"LLM config loaded (provider=anthropic)\"
  else
    echo \"No LLM API key configured (skipped)\"
  fi
"'

echo "==> Rebuilding and restarting orchestrator (no cache)..."
mise run ssh -- "cd /opt/orchestrator/repo && docker compose build --no-cache orchestrator && docker compose up -d orchestrator"

echo "==> Waiting for health check..."
DOMAIN=$(mise run ssh -- "grep PREVIEW_DOMAIN /opt/orchestrator/repo/.env | cut -d= -f2" 2>/dev/null)
if [[ -z "$DOMAIN" ]]; then
    echo "Error: Could not determine PREVIEW_DOMAIN from server .env" >&2
    exit 1
fi
for i in $(seq 1 30); do
    if curl -sf "https://api.${DOMAIN}/healthz" >/dev/null 2>&1; then
        echo "Deploy complete — orchestrator is healthy at https://api.${DOMAIN}/"
        exit 0
    fi
    sleep 2
done

echo "Warning: orchestrator did not become healthy within 60 seconds."
echo "Check logs: mise run ssh -- docker compose logs orchestrator"
exit 1
EOF
