  '"$(if [[ -n "$NEW_FB_PROVIDER" ]]; then echo "
  echo \"LLM_FALLBACK_PROVIDER=$NEW_FB_PROVIDER\" >> \"\$ENV_FILE\"
  echo \"LLM_FALLBACK_MODEL=$NEW_FB_MODEL\" >> \"\$ENV_FILE\"
  echo \"LLM_FALLBACK_API_KEY=$NEW_FB_API_KEY\" >> \"\$ENV_FILE\"
  "; fi)"'
  '"$(if [[ -n "$NEW_FB_BASE_URL" ]]; then echo "echo \"LLM_FALLBACK_BASE_URL=$NEW_FB_BASE_URL\" >> \"\$ENV_FILE\""; fi)"'

  echo \"Updated .env with new LLM configuration\"
"'

