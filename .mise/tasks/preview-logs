#!/usr/bin/env bash
#MISE description="Fetch logs from a preview deployment"
set -euo pipefail

# Parse arguments
REPO_OWNER="${1:-}"
REPO_NAME="${2:-}"
PR_NUMBER="${3:-}"
TAIL="${4:-100}"
FOLLOW="${5:-false}"

if [[ -z "$REPO_OWNER" || -z "$REPO_NAME" || -z "$PR_NUMBER" ]]; then
    echo "Usage: mise run preview-logs <owner> <repo> <pr-number> [tail-lines] [follow]"
    echo ""
    echo "Examples:"
    echo "  mise run preview-logs luminor-project luminor-core-go-playground 2"
    echo "  mise run preview-logs luminor-project luminor-core-go-playground 2 500"
    echo "  mise run preview-logs luminor-project luminor-core-go-playground 2 100 true"
    exit 1
fi

# Construct URL
DOMAIN="productbuilder.luminor-tech.net"
URL="https://api.${DOMAIN}/api/v1/previews/${REPO_OWNER}/${REPO_NAME}/${PR_NUMBER}/logs?tail=${TAIL}"

if [[ "$FOLLOW" == "true" ]]; then
    URL="${URL}&follow=true"
fi

echo "Fetching logs for ${REPO_OWNER}/${REPO_NAME}#${PR_NUMBER}..."
echo "URL: ${URL}"
echo ""

# Fetch logs (using curl with -N for no buffering when following)
if [[ "$FOLLOW" == "true" ]]; then
    curl -N -s "${URL}"
else
    curl -s "${URL}"
fi
