#!/usr/bin/env bash
#MISE description="Start the EC2 orchestrator instance"
set -euo pipefail

eval "$($(dirname "$0")/../lib/load-secrets)"

INSTANCE_ID=$(cd "$(dirname "$0")/../../infrastructure-mgmt/main" && tofu output -raw instance_id 2>/dev/null)

if [[ -z "$INSTANCE_ID" ]]; then
    echo "Error: Could not determine instance ID from tofu output" >&2
    exit 1
fi

echo "Starting instance $INSTANCE_ID..."
aws ec2 start-instances --instance-ids "$INSTANCE_ID" --output text
echo "Start request sent. Use 'mise run instance-status' to check."
