#!/usr/bin/env bash
#MISE description="Deploy latest code to the EC2 instance"
set -euo pipefail

echo "==> Pulling latest code on server..."
mise run ssh -- "cd /opt/orchestrator/repo && git pull"

echo "==> Refreshing target configs from Secrets Manager..."
mise run ssh -- 'sudo bash -c "
  REGION=\$(grep AWS_REGION /opt/orchestrator/repo/.env | cut -d= -f2)
  PREFIX=productbuilder/targets/
  TARGETS=\"[]\"
  for name in \$(aws secretsmanager list-secrets --region \"\$REGION\" \
    --filters \"Key=name,Values=\$PREFIX\" --query \"SecretList[].Name\" --output text); do
    VAL=\$(aws secretsmanager get-secret-value --region \"\$REGION\" \
      --secret-id \"\$name\" --query SecretString --output text)
    TARGETS=\$(echo \"\$TARGETS\" | jq --argjson item \"\$VAL\" \". + [\\\$item]\")
  done
  echo \"\$TARGETS\" > /opt/orchestrator/targets.json
  chmod 644 /opt/orchestrator/targets.json
  echo \"Loaded \$(echo \"\$TARGETS\" | jq length) target(s)\"
"'

echo "==> Refreshing Slack signing secret..."
mise run ssh -- 'sudo bash -c "
  REGION=\$(grep AWS_REGION /opt/orchestrator/repo/.env | cut -d= -f2)
  SECRET=\$(aws secretsmanager get-secret-value --region \"\$REGION\" \
    --secret-id productbuilder/slack-signing-secret \
    --query SecretString --output text 2>/dev/null || echo \"\")
  # Remove old value (if any) and append current
  sed -i /^SLACK_SIGNING_SECRET=/d /opt/orchestrator/repo/.env
  if [ -n \"\$SECRET\" ]; then
    echo \"SLACK_SIGNING_SECRET=\$SECRET\" >> /opt/orchestrator/repo/.env
    echo \"Slack signing secret loaded\"
  else
    echo \"No Slack signing secret configured (skipped)\"
  fi
"'

echo "==> Rebuilding and restarting orchestrator..."
mise run ssh -- "cd /opt/orchestrator/repo && docker compose up -d --build orchestrator"

echo "==> Waiting for health check..."
# Verify via Traefik — the orchestrator has no published ports, only preview-net.
DOMAIN=$(mise run ssh -- "grep PREVIEW_DOMAIN /opt/orchestrator/repo/.env | cut -d= -f2" 2>/dev/null || echo "productbuilder.luminor-tech.net")
for i in $(seq 1 30); do
    if curl -sf "https://api.${DOMAIN}/healthz" >/dev/null 2>&1; then
        echo "Deploy complete — orchestrator is healthy at https://api.${DOMAIN}/"
        exit 0
    fi
    sleep 2
done

echo "Warning: orchestrator did not become healthy within 60 seconds."
echo "Check logs: mise run ssh -- docker compose logs orchestrator"
exit 1
