#!/usr/bin/env bash
#MISE description="Decrypt secrets/*.enc → plaintext files (requires secrets/.key)"
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
KEY_FILE="$PROJECT_DIR/secrets/.key"

if [ ! -f "$KEY_FILE" ]; then
    echo ""
    echo "  The age secret key is missing at secrets/.key"
    echo ""
    echo "  To set it up:"
    echo "    1. Open 1Password and find the 'productbuilding orchestration age secret key' entry"
    echo "    2. Copy the key (starts with AGE-SECRET-KEY-...)"
    echo "    3. Paste it into secrets/.key:"
    echo ""
    echo "       pbpaste > secrets/.key    # macOS"
    echo ""
    echo "  See secrets/README.md for details."
    echo ""
    exit 1
fi

exec "$PROJECT_DIR/decrypt-secrets.sh"
